# =============================================================================
# TerraGraph — Environment Configuration
# Copy this file to .env and fill in the values before running docker-compose.
# =============================================================================

# ─── MySQL ──────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=terragraph_root_pass
MYSQL_DATABASE=terragraph_db
MYSQL_USER=terragraph_user
MYSQL_PASSWORD=terragraph_pass
MYSQL_EXTERNAL_PORT=3307

# ─── Backend ────────────────────────────────────────────────────────────────────
BACKEND_PORT=8080

# ─── Frontend ───────────────────────────────────────────────────────────────────
FRONTEND_PORT=3000

# ─── AI / LLM API Keys ─────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
GROQ_API_KEY=gsk_your-groq-api-key-here
